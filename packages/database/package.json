{
  "name": "@agent-loom/database",
  "private": true,
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/apply-sql-migrations.ts",
    "db:migrate:drizzle-kit": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "pg": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "tsx": "latest",
    "dotenv": "^16.4.5",
    "drizzle-kit": "latest",
    "@types/pg": "latest"
  }
}

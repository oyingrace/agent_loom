# Shared
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/agent_loom
REDIS_URL=redis://localhost:6379

# Web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: hostname embedded in signed auth messages (defaults to NEXT_PUBLIC_APP_URL hostname)
NEXT_PUBLIC_AUTH_DOMAIN=
WEB_PORT=3000
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Paid proxy x402 (optional; defaults in code if unset)
X402_FACILITATOR_URL=https://facilitator.stellar-x402.org
X402_FACILITATOR_API_KEY=
# Set to "false" to omit legacy memo block from 402 responses (x402-only clients)
X402_INCLUDE_LEGACY_MEMO_402=true

# Soroban RPC simulate + submit (required for user-signed workflow Soroban steps and Soroswap)
# STELLAR_RPC_URL is set above.
# Server hot wallet: only if a workflow step uses sorobanSigner "hot" or Soroswap MCP swap
WORKFLOW_HOT_WALLET_SECRET=
# Override defaults from https://github.com/soroswap/core/blob/main/public/testnet.contracts.json (etc.)
# SOROSWAP_ROUTER_TESTNET=
# SOROSWAP_ROUTER_MAINNET=

# Soroswap HTTP aggregator (https://api.soroswap.finance): quote / build / send — used by
# POST /api/soroswap/aggregator-swap, MCP soroswap_aggregator_swap, and stellar_buy_with_xlm (use_aggregator: true).
# SOROSWAP_API_KEY=sk_...
# Optional staging override:
# SOROSWAP_API_BASE_URL=https://staging-api.soroswap.finance

# Optional: GET URL for MCP tool stellar_trending_tokens (use {network} and {limit} placeholders).
# Return JSON { "tokens": [ { "contract": "C...", "symbol": "...", "rank": 1 } ] } or a JSON array.
# Mainnet requires this; testnet falls back to a tiny curated list when unset.
# STELLAR_TRENDING_API_URL=https://your-worker.example.com/trending?network={network}&limit={limit}

# Optional: override Stellar Asset Contract id for native XLM (defaults in nativeSac.ts).
# STELLAR_NATIVE_SAC_TESTNET=
# STELLAR_NATIVE_SAC_PUBLIC=

# MCP server (Streamable HTTP + OAuth resource metadata)
MCP_SERVER_PORT=3001
# Public URL of this MCP process (for OAuth protected-resource metadata). Falls back to request Host / proxies.
MCP_PUBLIC_URL=
# Same as web app origin; used for OAuth metadata and proxy tool calls. Defaults to NEXT_PUBLIC_APP_URL.
WEB_APP_URL=http://localhost:3000
MCP_SERVER_BASE_URL=http://localhost:3001
MCP_SERVER_SLUG_DEFAULT=default

# Security (iron-session requires password length >= 32)
APP_SESSION_SECRET=replace-with-at-least-32-characters-long-secret
SESSION_SECRET=32-hex
ENCRYPTION_SECRET=replace-me
